page {
  min-height: 100%;
  background:
    radial-gradient(circle at 18% 16%, rgba(237, 237, 165, 0.34) 0%, rgba(237, 237, 165, 0) 28%),
    radial-gradient(circle at 82% 22%, rgba(195, 169, 82, 0.16) 0%, rgba(195, 169, 82, 0) 24%),
    radial-gradient(circle at 50% 100%, rgba(124, 180, 163, 0.22) 0%, rgba(124, 180, 163, 0) 38%),
    linear-gradient(180deg, #d9e7dc 0%, #d4e3d5 18%, #dbe8d7 42%, #ecedd2 72%, #edf0de 100%);
  color: #2f4336;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  padding: 28rpx 28rpx 40rpx;
}

.hero-card,
.surface-card,
.journal-card {
  border-radius: 30rpx;
  border: 1rpx solid rgba(79, 110, 78, 0.1);
  box-shadow: 0 18rpx 54rpx rgba(79, 110, 78, 0.08);
  backdrop-filter: blur(10rpx);
}

.hero-card {
  padding: 36rpx 32rpx;
  background:
    radial-gradient(circle at 85% 20%, rgba(237, 237, 165, 0.28) 0%, rgba(237, 237, 165, 0) 30%),
    linear-gradient(145deg, rgba(137, 190, 173, 0.95), rgba(124, 180, 163, 0.92) 58%, rgba(113, 168, 150, 0.94) 100%);
}

.surface-card,
.journal-card {
  background:
    radial-gradient(circle at top right, rgba(237, 237, 165, 0.22) 0%, rgba(237, 237, 165, 0) 26%),
    linear-gradient(180deg, rgba(249, 249, 232, 0.94), rgba(243, 242, 214, 0.88));
}

.surface-card {
  padding: 28rpx;
  margin-top: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #405740;
}

.section-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(64, 87, 64, 0.72);
}

.headline {
  font-size: 46rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #3f5740;
}

.body-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #485a4b;
}

.muted-text {
  font-size: 24rpx;
  color: rgba(79, 110, 78, 0.64);
}

.primary-btn,
.secondary-btn,
.ghost-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.primary-btn {
  background: linear-gradient(135deg, #4f6e4e, #6a8f66);
  color: #f7f5d6;
  box-shadow: 0 14rpx 32rpx rgba(79, 110, 78, 0.18);
}

.primary-btn[disabled] {
  background: linear-gradient(135deg, rgba(149, 164, 149, 0.92), rgba(181, 191, 181, 0.92));
  color: rgba(255, 250, 232, 0.82);
  box-shadow: none;
}

.secondary-btn {
  background: rgba(237, 237, 165, 0.86);
  color: #4f6e4e;
  border: 1rpx solid rgba(195, 169, 82, 0.26);
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.14);
  color: #4f6e4e;
  border: 1rpx solid rgba(79, 110, 78, 0.2);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.emotion-tag,
.soft-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.emotion-tag {
  background: rgba(195, 169, 82, 0.2);
  color: #7a6935;
  border: 1rpx solid rgba(195, 169, 82, 0.16);
}

.soft-tag {
  background: rgba(124, 180, 163, 0.14);
  color: #4f6e4e;
  border: 1rpx solid rgba(79, 110, 78, 0.12);
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.info-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background:
    linear-gradient(180deg, rgba(246, 246, 216, 0.86), rgba(238, 241, 217, 0.78));
  border: 1rpx solid rgba(124, 180, 163, 0.14);
}

.info-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #8b7838;
}

.info-value {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #44584a;
}

.page-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 26rpx;
}

.journal-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.recent-card {
  padding: 24rpx;
}

.journal-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.journal-main {
  font-size: 34rpx;
  font-weight: 700;
  color: #476246;
}

.journal-keywords {
  margin-top: 12rpx;
  font-size: 25rpx;
  color: #8b7838;
}

.journal-snippet {
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: #4c5f4f;
}

.diary-box {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(236, 238, 213, 0.88);
  font-size: 28rpx;
  line-height: 1.9;
  color: #45584a;
  white-space: pre-line;
}

.empty-state {
  padding: 64rpx 28rpx;
  text-align: center;
}
