.result-hero {
  text-align: center;
}

.result-main {
  margin-top: 18rpx;
  font-size: 82rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #27443a;
}

.result-tags {
  justify-content: center;
  margin-top: 24rpx;
}

.source-tag {
  background: rgba(50, 85, 74, 0.12);
  color: #35554a;
}

.detail-list {
  margin-top: 24rpx;
}

.analysis-text {
  margin-top: 18rpx;
}

.risk-card {
  border-color: rgba(184, 103, 89, 0.18);
  background: linear-gradient(180deg, rgba(255, 247, 244, 0.96), rgba(255, 251, 247, 0.96));
}

.risk-note {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(184, 103, 89, 0.08);
  font-size: 24rpx;
  line-height: 1.7;
  color: #8e5b4f;
}

.loading-card {
  text-align: center;
  padding-top: 60rpx;
  padding-bottom: 60rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 36rpx;
}

.loading-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #4f8473;
  animation: pulse 1.2s infinite ease-in-out;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

.top-gap-lg {
  margin-top: 24rpx;
}

@keyframes pulse {
  0%,
  80%,
  100% {
    opacity: 0.28;
    transform: scale(0.85);
  }

  40% {
    opacity: 1;
    transform: scale(1);
  }
}
