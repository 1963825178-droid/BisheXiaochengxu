.hero-with-account {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.account-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.account-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(71, 116, 101, 0.2), rgba(255, 251, 245, 0.96));
  border: 1rpx solid rgba(71, 116, 101, 0.15);
  font-size: 38rpx;
  font-weight: 700;
  color: #32564b;
}

.account-label {
  font-size: 24rpx;
  color: #61736c;
}

.entry-box {
  width: 100%;
  min-height: 260rpx;
  box-sizing: border-box;
  margin: 24rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
  font-size: 30rpx;
  line-height: 1.75;
  color: #31403c;
}

.entry-placeholder {
  color: #9aa09d;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
}

.example-chip {
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(241, 232, 217, 0.82);
  font-size: 26rpx;
  line-height: 1.6;
  color: #5e5748;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.shortcut-card {
  min-height: 180rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 251, 245, 0.96), rgba(242, 233, 220, 0.86));
}

.shortcut-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #30403b;
}

.shortcut-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6d766f;
}

.empty-inline {
  margin-top: 20rpx;
}
