.hero-with-account {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.account-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.account-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 28% 22%, rgba(237, 237, 165, 0.34) 0%, rgba(237, 237, 165, 0) 34%),
    linear-gradient(145deg, rgba(242, 245, 214, 0.92), rgba(124, 180, 163, 0.86));
  border: 1rpx solid rgba(79, 110, 78, 0.12);
  box-shadow: 0 12rpx 28rpx rgba(79, 110, 78, 0.12);
  font-size: 38rpx;
  font-weight: 700;
  color: #4f6e4e;
}

.account-avatar-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: block;
  overflow: hidden;
  border: 1rpx solid rgba(79, 110, 78, 0.14);
  box-shadow: 0 12rpx 28rpx rgba(79, 110, 78, 0.12);
}

.account-label {
  font-size: 24rpx;
  color: rgba(79, 110, 78, 0.82);
}

.entry-box {
  width: 100%;
  min-height: 260rpx;
  box-sizing: border-box;
  margin: 24rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(251, 251, 236, 0.94), rgba(247, 248, 227, 0.88));
  border: 1rpx solid rgba(124, 180, 163, 0.16);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  font-size: 30rpx;
  line-height: 1.75;
  color: #3d5143;
}

.entry-placeholder {
  color: rgba(79, 110, 78, 0.42);
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.shortcut-card {
  min-height: 180rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(124, 180, 163, 0.16) 0%, rgba(124, 180, 163, 0) 34%),
    linear-gradient(180deg, rgba(248, 248, 221, 0.92), rgba(238, 237, 187, 0.72));
  border: 1rpx solid rgba(195, 169, 82, 0.12);
}

.shortcut-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #476246;
}

.shortcut-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(79, 110, 78, 0.76);
}

.empty-inline {
  margin-top: 20rpx;
}
