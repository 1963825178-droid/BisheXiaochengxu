<view class="page-shell">
  <view class="hero-card account-hero">
    <button class="avatar-picker compact-avatar" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar" hover-class="none">
      <image wx:if="{{avatarPreviewUrl}}" class="account-avatar-image compact-avatar" src="{{avatarPreviewUrl}}" mode="aspectFill" />
      <view wx:else class="account-avatar compact-avatar">{{accountAvatarText}}</view>
    </button>

    <view class="account-copy">
      <view class="section-title">我的资料</view>
      <view class="nickname-pill">{{editingNickname || '微信用户'}}</view>
      <view class="section-subtitle">点击头像以用微信账号登录；本应用承诺不会恶意泄露用户隐私信息。</view>
    </view>
  </view>

  <view class="surface-card">
    <view class="section-title">账号概览</view>
    <view class="info-list top-gap">
      <view class="info-item">
        <view class="info-label">云端日记数量</view>
        <view class="info-value">{{user ? user.journalCount : 0}} 条</view>
      </view>
      <view class="info-item">
        <view class="info-label">本地迁移状态</view>
        <view class="info-value">{{user && user.localMigrationDone ? '已完成' : '待同步'}}</view>
      </view>
    </view>
  </view>

  <view class="surface-card">
    <view class="section-title">快捷入口</view>
    <view class="shortcut-grid">
      <view class="shortcut-card" bindtap="goCalendar">
        <view class="shortcut-title">我的日历</view>
        <view class="shortcut-desc">按日期查看当前账号下的所有情绪日记</view>
      </view>
      <view class="shortcut-card" bindtap="goStats">
        <view class="shortcut-title">月度统计</view>
        <view class="shortcut-desc">查看自己的情绪趋势和最近保存</view>
      </view>
    </view>
  </view>

  <view class="page-actions">
    <button class="secondary-btn" bindtap="syncLocalJournals">{{syncButtonText}}</button>
  </view>

  <view wx:if="{{showNicknameModal}}" class="modal-mask" catchtap="noop" catchtouchmove="noop">
    <view class="nickname-modal" catchtap="noop">
      <view class="modal-title">确认昵称</view>
      <view class="modal-desc">你可以自定义昵称。头像和昵称仅用于展示，不影响日记归属。</view>
      <input
        class="modal-nickname-input"
        type="text"
        maxlength="20"
        placeholder="请输入你想展示的昵称"
        placeholder-class="nickname-placeholder"
        value="{{editingNickname}}"
        focus="{{nicknameModalFocus}}"
        confirm-type="done"
        bindinput="handleNicknameInput"
        bindconfirm="handleNicknameKeyboardConfirm"
      />
      <button
        class="primary-btn modal-confirm-btn"
        disabled="{{!canConfirmNickname || isSavingProfile}}"
        loading="{{isSavingProfile}}"
        bindtap="handleNicknameModalConfirm"
      >
        确认并同步
      </button>
    </view>
  </view>
</view>
