<view class="page-shell">
  <view class="hero-card account-hero">
    <view class="account-profile-row">
      <view class="avatar-panel">
        <view class="avatar-visual profile-avatar">
          <image
            wx:if="{{avatarPreviewUrl}}"
            class="account-avatar-image profile-avatar"
            src="{{avatarPreviewUrl}}"
            mode="aspectFill"
            binderror="handleAvatarImageError"
          />
          <view wx:else class="account-avatar profile-avatar">{{accountAvatarText}}</view>
          <button
            class="avatar-picker-overlay"
            open-type="chooseAvatar"
            bindtouchstart="handleAvatarPickerTouchStart"
            bindtap="handleAvatarPickerTap"
            bindchooseavatar="handleChooseAvatar"
            hover-class="none"
            disabled="{{isAvatarPickerActive || isSavingAvatar}}"
          />
        </view>
      </view>

      <view class="account-copy">
        <view class="nickname-shell">
          <view class="nickname-label-row">
            <view class="nickname-label">我的昵称</view>
            <view wx:if="{{isSavingNickname}}" class="nickname-status nickname-status-saving">正在保存昵称</view>
            <view wx:elif="{{canSubmitNickname}}" class="nickname-status nickname-status-pending">选定后会自动保存</view>
            <view wx:else class="nickname-status">当前昵称已同步</view>
          </view>
          <input
            class="nickname-input"
            name="nickname"
            type="nickname"
            maxlength="20"
            placeholder="点击昵称框以设置昵称"
            placeholder-class="nickname-placeholder"
            value="{{editingNickname}}"
            confirm-type="done"
            disabled="{{isSavingNickname || isSavingAvatar}}"
            bindinput="handleNicknameInput"
            bindblur="handleNicknameBlur"
            bindconfirm="handleNicknameKeyboardConfirm"
          />
        </view>
      </view>
    </view>

    <view class="section-subtitle account-hint">
      点击头像以设置头像；点击昵称框以设置昵称；本应用承诺不会恶意泄露用户隐私信息。
    </view>
  </view>

  <view class="surface-card">
    <view class="section-title">账号概览</view>
    <view class="info-list top-gap">
      <view class="info-item">
        <view class="info-label">云端日记数量</view>
        <view class="info-value">{{user ? user.journalCount : 0}} 条</view>
      </view>
      <view class="info-item">
        <view class="info-label">本地迁移状态</view>
        <view class="info-value">{{user && user.localMigrationDone ? '已完成' : '待同步'}}</view>
      </view>
    </view>
  </view>

  <view class="surface-card">
    <view class="section-title">快捷入口</view>
    <view class="shortcut-grid">
      <view class="shortcut-card" bindtap="goCalendar">
        <view class="shortcut-title">我的日历</view>
        <view class="shortcut-desc">按日期查看当前账号下的所有情绪日记</view>
      </view>
      <view class="shortcut-card" bindtap="goStats">
        <view class="shortcut-title">月度统计</view>
        <view class="shortcut-desc">查看自己的情绪趋势和最近保存</view>
      </view>
    </view>
  </view>

  <view class="page-actions">
    <button class="secondary-btn" bindtap="syncLocalJournals">{{syncButtonText}}</button>
  </view>
</view>
