.account-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.large-avatar {
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
}

.account-copy {
  flex: 1;
  min-width: 0;
}

.account-avatar {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(71, 116, 101, 0.2), rgba(255, 251, 245, 0.96));
  border: 1rpx solid rgba(71, 116, 101, 0.15);
  font-size: 42rpx;
  font-weight: 700;
  color: #32564b;
}

.top-gap {
  margin-top: 20rpx;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.shortcut-card {
  min-height: 180rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 251, 245, 0.96), rgba(242, 233, 220, 0.86));
}

.shortcut-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #30403b;
}

.shortcut-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6d766f;
}
