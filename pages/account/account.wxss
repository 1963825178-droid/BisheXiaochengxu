.account-hero {
  padding: 26rpx 26rpx 24rpx;
}

.account-profile-row {
  display: flex;
  align-items: stretch;
  gap: 22rpx;
}

.profile-avatar {
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
}

.avatar-panel {
  flex: 0 0 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.account-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.avatar-visual {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-picker-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  background: transparent;
  background-color: transparent;
  border: none;
  line-height: normal;
  box-sizing: border-box;
  opacity: 0;
}

.avatar-picker-overlay::after {
  border: none;
}

.avatar-picker-overlay[disabled] {
  pointer-events: none;
}

.account-avatar {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 30% 24%, rgba(237, 237, 165, 0.36) 0%, rgba(237, 237, 165, 0) 32%),
    linear-gradient(145deg, rgba(238, 243, 213, 0.94), rgba(124, 180, 163, 0.88));
  border: 1rpx solid rgba(79, 110, 78, 0.14);
  box-shadow: 0 12rpx 28rpx rgba(79, 110, 78, 0.12);
  font-size: 40rpx;
  font-weight: 700;
  color: #4f6e4e;
}

.account-avatar-image {
  border-radius: 50%;
  display: block;
  overflow: hidden;
  border: 1rpx solid rgba(79, 110, 78, 0.14);
  box-shadow: 0 12rpx 28rpx rgba(79, 110, 78, 0.12);
}

.nickname-shell {
  width: 100%;
  min-width: 0;
  min-height: 132rpx;
  padding: 20rpx 22rpx;
  border-radius: 26rpx;
  background:
    linear-gradient(180deg, rgba(252, 251, 239, 0.94), rgba(246, 246, 225, 0.8));
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.52),
    0 10rpx 26rpx rgba(79, 110, 78, 0.06);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nickname-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10rpx 14rpx;
  margin-bottom: 16rpx;
}

.nickname-label {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(64, 87, 64, 0.8);
  line-height: 1.2;
}

.nickname-status {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.52);
  color: rgba(64, 87, 64, 0.62);
  font-size: 20rpx;
  line-height: 1.2;
}

.nickname-status-pending {
  background: rgba(237, 237, 165, 0.42);
  color: #7a6935;
}

.nickname-status-saving {
  background: rgba(124, 180, 163, 0.22);
  color: #476246;
}

.nickname-input {
  width: 100%;
  min-width: 0;
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 251, 0.96);
  border: 1rpx solid rgba(79, 110, 78, 0.12);
  color: #476246;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 78rpx;
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.65);
}

.nickname-placeholder {
  color: rgba(79, 110, 78, 0.44);
}

.account-hint {
  margin-top: 18rpx;
  line-height: 1.72;
}

.top-gap {
  margin-top: 20rpx;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.shortcut-card {
  min-height: 180rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(124, 180, 163, 0.18) 0%, rgba(124, 180, 163, 0) 32%),
    linear-gradient(180deg, rgba(248, 248, 220, 0.92), rgba(240, 239, 194, 0.74));
  border: 1rpx solid rgba(195, 169, 82, 0.14);
}

.shortcut-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #476246;
}

.shortcut-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(79, 110, 78, 0.76);
}
