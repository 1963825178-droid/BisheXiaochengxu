.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.calendar-title {
  font-size: 42rpx;
  text-align: center;
}

.month-switch {
  min-width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 999rpx;
  padding: 0 24rpx;
  background: rgba(237, 237, 165, 0.76);
  border: 1rpx solid rgba(195, 169, 82, 0.18);
  color: #4f6e4e;
  font-size: 26rpx;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
}

.week-row {
  margin-bottom: 14rpx;
}

.week-cell {
  text-align: center;
  font-size: 24rpx;
  color: rgba(79, 110, 78, 0.62);
}

.day-cell {
  min-height: 128rpx;
  padding: 16rpx 10rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background:
    linear-gradient(180deg, rgba(248, 248, 223, 0.82), rgba(241, 241, 199, 0.68));
  border: 1rpx solid rgba(124, 180, 163, 0.1);
}

.day-cell--muted {
  opacity: 0.34;
}

.day-cell--selected {
  background:
    radial-gradient(circle at top, rgba(237, 237, 165, 0.3) 0%, rgba(237, 237, 165, 0) 34%),
    linear-gradient(180deg, rgba(143, 193, 177, 0.96), rgba(124, 180, 163, 0.94));
  box-shadow: inset 0 0 0 2rpx rgba(79, 110, 78, 0.16), 0 10rpx 26rpx rgba(79, 110, 78, 0.12);
}

.day-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #426042;
}

.day-dot {
  margin-top: 18rpx;
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(195, 169, 82, 0.22);
  color: #756633;
  font-size: 20rpx;
}

.empty-inline {
  margin-top: 20rpx;
}
