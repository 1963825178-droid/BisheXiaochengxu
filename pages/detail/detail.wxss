.detail-tags {
  margin-top: 22rpx;
}

.top-gap {
  margin-top: 18rpx;
}

.loading-card {
  text-align: center;
  padding-top: 60rpx;
  padding-bottom: 60rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 36rpx;
}

.loading-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #7cb4a3;
  animation: pulse 1.2s infinite ease-in-out;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

.danger-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
  background: rgba(170, 111, 92, 0.12);
  color: #8b5c4b;
  border: 1rpx solid rgba(170, 111, 92, 0.2);
}

@keyframes pulse {
  0%,
  80%,
  100% {
    opacity: 0.28;
    transform: scale(0.85);
  }

  40% {
    opacity: 1;
    transform: scale(1);
  }
}
