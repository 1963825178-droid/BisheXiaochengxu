<view class="page-shell">
  <view wx:if="{{status === 'loading'}}" class="surface-card loading-card">
    <view class="section-title">加载中</view>
    <view class="section-subtitle">正在读取这条情绪日记，请稍等片刻。</view>
    <view class="loading-wrap">
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
    </view>
  </view>

  <block wx:elif="{{status === 'succeeded' && journal}}">
    <view class="hero-card">
      <view class="muted-text">保存时间</view>
      <view class="headline">{{journal.mainEmotion}}</view>
      <view class="section-subtitle">{{journal.displayTimeText}}</view>
      <view class="tag-row detail-tags">
        <view wx:if="{{sourceLabel}}" class="soft-tag">{{sourceLabel}}</view>
        <view class="emotion-tag">{{journal.mainEmotion}}</view>
        <view wx:for="{{journal.subEmotions}}" wx:key="*this" class="soft-tag">{{item}}</view>
      </view>
    </view>

    <view class="surface-card">
      <view class="section-title">你的记录</view>
      <view class="body-text top-gap">{{journal.rawInput}}</view>
    </view>

    <view class="surface-card">
      <view class="section-title">关键词与解释</view>
      <view class="info-list top-gap">
        <view wx:for="{{explanationPairs}}" wx:key="emotion" class="info-item">
          <view class="info-label">{{item.emotion}}</view>
          <view class="info-value">{{item.description}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{journal.foreignEmotionWord}}" class="surface-card foreign-word-card">
      <view class="section-title">更贴近的外文词</view>
      <view class="foreign-word-row">
        <view class="foreign-word">{{journal.foreignEmotionWord.word}}</view>
        <view class="soft-tag">{{journal.foreignEmotionWord.language}}</view>
      </view>
      <view class="body-text foreign-word-meaning">{{journal.foreignEmotionWord.meaning}}</view>
    </view>

    <view class="surface-card">
      <view class="section-title">情绪解析</view>
      <view class="body-text top-gap">{{journal.analysis}}</view>
    </view>

    <view class="surface-card {{journal.riskLevel === 'high' ? 'risk-card' : ''}}">
      <view class="section-title">{{suggestionTitle}}</view>
      <view class="body-text top-gap">{{journal.suggestion}}</view>
      <view wx:if="{{journal.riskLevel === 'high'}}" class="risk-note">
        说明：这里不会做诊断，只提醒你先联系现实支持资源，优先保证安全。
      </view>
    </view>

    <view class="page-actions">
      <button class="danger-btn" bindtap="deleteJournal">删除这条日记</button>
      <button class="secondary-btn" bindtap="goHome">回到首页继续记录</button>
    </view>
  </block>

  <view wx:else class="surface-card empty-state">
    <view class="section-title">没有找到这条日记</view>
    <view class="section-subtitle">{{errorMessage}}</view>
    <button class="primary-btn" bindtap="goHome">回到首页</button>
  </view>
</view>
