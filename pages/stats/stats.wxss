.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.calendar-title {
  font-size: 42rpx;
  text-align: center;
}

.month-switch {
  min-width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 999rpx;
  padding: 0 24rpx;
  background: rgba(237, 237, 165, 0.76);
  border: 1rpx solid rgba(195, 169, 82, 0.18);
  color: #4f6e4e;
  font-size: 26rpx;
}

.top-gap {
  margin-top: 18rpx;
}

.bar-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.bar-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bar-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #476246;
}

.bar-track {
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(79, 110, 78, 0.1);
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
}

.ratio-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(248, 248, 222, 0.88), rgba(239, 238, 195, 0.72));
}

.ratio-track {
  display: flex;
  width: 100%;
  height: 22rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(79, 110, 78, 0.1);
}

.ratio-positive {
  height: 100%;
  background: linear-gradient(90deg, #c3a952, #e6dd8e);
}

.ratio-negative {
  height: 100%;
  background: linear-gradient(90deg, #5b7d5c, #7cb4a3);
}

.ratio-labels {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}
