.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.calendar-title {
  font-size: 42rpx;
  text-align: center;
}

.month-switch {
  min-width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 999rpx;
  padding: 0 24rpx;
  background: rgba(237, 237, 165, 0.76);
  border: 1rpx solid rgba(195, 169, 82, 0.18);
  color: #4f6e4e;
  font-size: 26rpx;
}

.top-gap {
  margin-top: 18rpx;
}

.bento-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.bento-item {
  border-radius: 22rpx;
  padding: 18rpx 14rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: transform 0.15s ease;
}

.bento-item:active {
  transform: scale(0.97);
}

.bento-large {
  width: 60%;
  height: 240rpx;
}

.bento-medium {
  width: 40%;
  height: 180rpx;
}

.bento-small {
  width: 33.33%;
  height: 130rpx;
}

.bento-content {
  text-align: center;
  width: 100%;
}

.bento-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d4a2c;
  margin-bottom: 6rpx;
  letter-spacing: 2rpx;
}

.bento-large .bento-name {
  font-size: 38rpx;
}

.bento-small .bento-name {
  font-size: 28rpx;
}

.bento-count {
  font-size: 24rpx;
  font-weight: 600;
  color: #476246;
}

.bento-large .bento-count {
  font-size: 28rpx;
}

.bento-small .bento-count {
  font-size: 20rpx;
}

.ratio-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(248, 248, 222, 0.88), rgba(239, 238, 195, 0.72));
}

.ratio-track {
  display: flex;
  width: 100%;
  height: 22rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(79, 110, 78, 0.1);
}

.ratio-positive {
  height: 100%;
  background: linear-gradient(90deg, #c3a952, #e6dd8e);
}

.ratio-negative {
  height: 100%;
  background: linear-gradient(90deg, #5b7d5c, #7cb4a3);
}

.ratio-labels {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.beta-refresh-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: rgba(237, 237, 165, 0.76);
  border: 1rpx solid rgba(195, 169, 82, 0.18);
  color: #4f6e4e;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0 24rpx;
  text-align: center;
}
